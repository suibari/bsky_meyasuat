# PostgREST (db.suibari.com)
# JWT 認証なし構成 (Cloudflare Access で保護)
POSTGREST_URL="https://db.suibari.com"

# Cloudflare Access (db.suibari.com 保護)
CF_ACCESS_CLIENT_ID="xxxxx.access"
CF_ACCESS_CLIENT_SECRET="yyyyyyy"

# Bluesky Bot アカウント
BOT_HANDLE="meyasuat-bot.bsky.social"
BOT_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# Cloudflare R2
R2_PUBLIC_URL="https://images.meyasuat.pages.dev"

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY="0x..."
PUBLIC_TURNSTILE_SITE_KEY="0x..."

# セッション Cookie 署名用シークレット (openssl rand -hex 32 で生成)
SESSION_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# アプリ URL (OAuth redirect_uri と一致させること)
PUBLIC_APP_URL="https://meyasuat.pages.dev"
