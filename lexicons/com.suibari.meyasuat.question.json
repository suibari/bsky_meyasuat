{
	"lexicon": 1,
	"id": "com.suibari.meyasuat.question",
	"defs": {
		"main": {
			"type": "record",
			"description": "A named question sent through meyasuat, recorded in the sender's own repo.",
			"key": "tid",
			"record": {
				"type": "object",
				"required": ["subject", "text", "url", "createdAt"],
				"properties": {
					"subject": {
						"type": "string",
						"format": "did",
						"description": "DID of the meyasuat box owner the question was sent to."
					},
					"text": {
						"type": "string",
						"maxLength": 30000,
						"maxGraphemes": 10000,
						"description": "The question text."
					},
					"images": {
						"type": "array",
						"maxLength": 4,
						"items": {
							"type": "blob",
							"accept": ["image/jpeg", "image/png", "image/webp"],
							"maxSize": 1000000
						}
					},
					"url": {
						"type": "string",
						"format": "uri",
						"description": "Link to the meyasuat message page."
					},
					"createdAt": {
						"type": "string",
						"format": "datetime"
					}
				}
			}
		}
	}
}
